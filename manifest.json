{
  "manifest_version": 3,
  "name": "COIG – Przypomnienie o wniosku",
  "version": "1.0",
  "description": "Przypomina o wystawieniu wniosku o pracę w wybrany dzień tygodnia.",
  "permissions": [
    "notifications",
    "storage",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "COIG Przypomnienie"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
